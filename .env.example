# Generic database configuration
APP_DATABASE_URL=
DATABASE_URL=
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_NAME=
DATABASE_PROD_NAME=
DATABASE_DEV_NAME=
DATABASE_SQLALCHEMY_SCHEME=postgresql+psycopg2
DATABASE_SSLMODE=require
DATABASE_SSLROOTCERT=
DATABASE_LABEL=SQL database
SQL_DIALECT=postgres

# Legacy compatibility
REDSHIFT_HOST=
REDSHIFT_PORT=5439
REDSHIFT_USER=
REDSHIFT_PASSWORD=
REDSHIFT_DATABASE=
REDSHIFT_PROD_DATABASE=
REDSHIFT_DEV_DATABASE=
REDSHIFT_SQLALCHEMY_SCHEME=postgresql+psycopg2
REDSHIFT_SSLMODE=require
REDSHIFT_SSLROOTCERT=

ALLOWED_TABLES=public.orders,public.customers
MAX_RESULT_ROWS=200
MARKDOWN_DOCS_DIR=docs/markdown

# Example SQLite configuration
# APP_DATABASE_URL=sqlite:////absolute/path/to/examples/chinook/data/chinook.sqlite
# SQL_DIALECT=sqlite
# ALLOWED_TABLES=Album,Artist,Customer
# MARKDOWN_DOCS_DIR=/absolute/path/to/examples/chinook/docs/markdown

# Example IMDb Postgres configuration
# IMDb data is subject to IMDb's non-commercial dataset terms:
# https://developer.imdb.com/non-commercial-datasets/
# https://datasets.imdbws.com/
# APP_DATABASE_URL=postgresql+psycopg2://alfredo@localhost:5432/imdb
# SQL_DIALECT=postgres
# DATABASE_LABEL=IMDb Postgres database
# ALLOWED_TABLES=imdb_core.title_genre,imdb_core.title_director,imdb_core.title_writer,imdb_core.name_known_for_title,imdb_core.name_primary_profession,imdb_raw.title_basics,imdb_raw.name_basics,imdb_raw.title_ratings,imdb_raw.title_principals,imdb_raw.title_episode
# MARKDOWN_DOCS_DIR=/absolute/path/to/examples/imdb/docs/markdown

# Model selection
MODEL_PROVIDER=huggingface
MODEL_ID=Qwen/Qwen2.5-Coder-32B-Instruct

# Hugging Face
HF_TOKEN=

# OpenAI-compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Google AI Studio / LiteLLM
GOOGLE_API_KEY=
GOOGLE_API_BASE=

# Gemma 4 / Ollama
# Ollama's current Gemma 4 edge tags are `gemma4:e2b` and `gemma4:e4b`.
# The app also accepts MODEL_ID=gemma4:2b and MODEL_ID=gemma4:4b as aliases.
# MODEL_PROVIDER=ollama
# MODEL_ID=gemma4:e2b
# OLLAMA_BASE_URL=http://localhost:11434/v1
# Required setup:
# ollama serve
# ollama pull gemma4:e2b

# Google hosted example
# MODEL_PROVIDER=google
# MODEL_ID=gemini/gemini-2.5-flash-lite
# GOOGLE_API_KEY=your-google-api-key
